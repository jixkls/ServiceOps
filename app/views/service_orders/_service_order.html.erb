<div id="<%= dom_id service_order %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Code:</strong>
    <%= service_order.code %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Customer:</strong>
    <%= service_order.customer.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Assigned user:</strong>
    <%= service_order.assigned_user&.email_address || "—" %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Service category:</strong>
    <%= service_order.service_category.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= service_order.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= service_order.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= service_order.status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Priority:</strong>
    <%= service_order.priority %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Public token:</strong>
    <%= service_order.public_token %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Opened at:</strong>
    <%= service_order.opened_at %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Finished at:</strong>
    <%= service_order.finished_at %>
  </div>
</div>
