<% content_for :title, "Showing service order" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing service order</h1>

  <%= render @service_order %>

  <div class="my-5 border-t border-gray-200 pt-5">
    <h2 class="font-bold text-2xl mb-3">Diagnóstico</h2>
    <% if @service_order.diagnostic.present? %>
      <div class="space-y-3">
        <div>
          <strong class="block font-medium mb-1">Resumo:</strong>
          <%= @service_order.diagnostic.summary %>
        </div>
        <div>
          <strong class="block font-medium mb-1">Detalhes técnicos:</strong>
          <%= @service_order.diagnostic.technical_details %>
        </div>
        <div>
          <strong class="block font-medium mb-1">Registrado por:</strong>
          <%= @service_order.diagnostic.user.email_address %>
        </div>
      </div>
      <%= link_to "Editar diagnóstico", edit_service_order_diagnostic_path(@service_order), class: "w-full sm:w-auto text-center mt-3 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <% else %>
      <p class="text-gray-600 mb-3">Nenhum diagnóstico registrado.</p>
      <%= link_to "Registrar diagnóstico", new_service_order_diagnostic_path(@service_order), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium" %>
    <% end %>
  </div>

  <%= link_to "Edit this service order", edit_service_order_path(@service_order), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to service orders", service_orders_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= button_to "Destroy this service order", @service_order, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>
