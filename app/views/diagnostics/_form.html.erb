<%# Recurso singular aninhado: a URL é sempre service_order_diagnostic_path.
    O form_with infere o método (POST para novo, PATCH para existente) pelo persisted?. %>
<%= form_with(model: diagnostic, url: service_order_diagnostic_path(service_order), class: "contents") do |form| %>
  <% if diagnostic.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(diagnostic.errors.count, "error") %> prohibited this diagnostic from being saved:</h2>

      <ul class="list-disc ml-6">
        <% diagnostic.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% field_classes = "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>

  <div class="my-5">
    <%= form.label :summary, "Resumo" %>
    <%= form.text_field :summary, class: field_classes %>
  </div>

  <div class="my-5">
    <%= form.label :technical_details, "Detalhes técnicos" %>
    <%= form.textarea :technical_details, rows: 6, class: field_classes %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
